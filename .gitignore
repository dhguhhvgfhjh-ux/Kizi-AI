```html
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kizi AI Assistant v1.0 (Alpha Test)</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- FontAwesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Quicksand', sans-serif;
      background: radial-gradient(circle at center, #0e1e12 0%, #050a06 100%);
    }
    .kizi-font {
      font-family: 'Fredoka One', cursive;
    }
    .kizi-glow {
      box-shadow: 0 0 15px rgba(34, 197, 94, 0.4);
    }
    .kizi-glow-intense {
      box-shadow: 0 0 25px rgba(34, 197, 94, 0.7);
    }
    /* Hide scrollbars but keep functionality */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    /* Simple retro CRT effect */
    .crt::after {
      content: " ";
      display: block;
      position: absolute;
      top: 0; left: 0; bottom: 0; right: 0;
      background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
      z-index: 20;
      background-size: 100% 2px, 3px 100%;
      pointer-events: none;
    }
  </style>
</head>
<body class="text-gray-100 min-h-full flex flex-col overflow-x-hidden antialiased">

  <!-- Header -->
  <header class="border-b border-green-900/40 bg-black/40 backdrop-blur-md sticky top-0 z-50 px-4 py-3">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <!-- Cute Custom Animated Kizi SVG Logo -->
        <div class="relative w-10 h-10 bg-green-500 rounded-full flex items-center justify-center kizi-glow animate-bounce">
          <svg class="w-8 h-8 text-black" viewBox="0 0 64 64" fill="currentColor">
            <!-- Big Alien Eye -->
            <circle cx="32" cy="30" r="14" fill="white" />
            <circle cx="32" cy="30" r="6" fill="black" />
            <circle cx="29" cy="27" r="2" fill="white" />
            <!-- Antennae -->
            <path d="M 22 16 L 16 6" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            <circle cx="16" cy="6" r="3" fill="currentColor"/>
            <path d="M 42 16 L 48 6" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            <circle cx="48" cy="6" r="3" fill="currentColor"/>
            <!-- Smile -->
            <path d="M 24 45 Q 32 52 40 45" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
          </svg>
          <span class="absolute -top-1 -right-1 flex h-3.5 w-3.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-green-500"></span>
          </span>
        </div>
        <div>
          <h1 class="kizi-font text-2xl text-green-400 tracking-wider flex items-center gap-1.5">
            KIZI AI <span class="text-xs bg-green-900/60 text-green-300 border border-green-500/30 px-2 py-0.5 rounded-full uppercase font-sans tracking-normal">Alpha v1.0</span>
          </h1>
          <p class="text-[10px] text-green-500 tracking-widest uppercase">The Ultimate Gaming Companion</p>
        </div>
      </div>

      <!-- Quick status / indicators -->
      <div class="flex items-center space-x-4 text-xs">
        <div class="hidden sm:flex items-center space-x-2 bg-green-950/40 border border-green-500/20 px-3 py-1.5 rounded-full">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          <span class="text-green-300 font-mono">SYSTEMS: ONLINE</span>
        </div>
        <button id="tts-toggle" class="p-2.5 rounded-full bg-green-950/60 hover:bg-green-800/40 border border-green-500/30 text-green-400 transition-all" title="Toggle Voice Responses">
          <i id="tts-icon" class="fas fa-volume-up"></i>
        </button>
      </div>
    </div>
  </header>

  <!-- Main Grid Layout -->
  <main class="flex-grow max-w-7xl w-full mx-auto p-4 grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">
    
    <!-- Left Column: AI Assistant Terminal & Walkthrough Generator (Lg: 7 cols) -->
    <div class="lg:col-span-7 flex flex-col space-y-6">
      
      <!-- AI Conversation Console -->
      <div class="bg-black/60 border border-green-900/60 rounded-3xl overflow-hidden flex flex-col h-[550px] relative kizi-glow">
        <!-- Console Header -->
        <div class="bg-gradient-to-r from-green-950/80 to-black/80 px-4 py-3 border-b border-green-900/40 flex items-center justify-between">
          <div class="flex items-center space-x-2">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <span class="text-xs font-mono text-green-400 ml-2">kizi_assistant_core.sh</span>
          </div>
          <button id="clear-chat" class="text-xs text-green-500 hover:text-green-300 transition-colors flex items-center gap-1">
            <i class="fas fa-trash"></i> Reset Chat
          </button>
        </div>

        <!-- Chat Area -->
        <div id="chat-messages" class="flex-grow overflow-y-auto p-4 space-y-4 no-scrollbar">
          <!-- Greeting Message -->
          <div class="flex items-start space-x-3">
            <div class="w-9 h-9 bg-green-500 rounded-full flex-shrink-0 flex items-center justify-center text-black font-bold">
              👽
            </div>
            <div class="bg-green-950/40 border border-green-500/20 text-green-100 p-3.5 rounded-2xl rounded-tl-none max-w-[85%] text-sm leading-relaxed">
              <p class="font-bold text-green-400 mb-1">Kizi AI:</p>
              Hey gamer! I'm <strong class="text-green-300">Kizi</strong>, your friendly alien mascot gaming companion. 💚👽 Ready to master your favorite web games, discover awesome retro challenges, or talk game strategies? 
              <br><br>
              Try asking me for walkthroughs of classic flash games like *Fireboy & Watergirl*, *Bob the Robber*, or ask me to generate a custom retro text game! 🎮🔥
            </div>
          </div>
        </div>

        <!-- Typing Indicator (Hidden) -->
        <div id="typing-indicator" class="hidden px-6 py-3 bg-green-950/20 text-xs text-green-400 flex items-center space-x-2">
          <div class="flex space-x-1">
            <div class="w-1.5 h-1.5 bg-green-400 rounded-full animate-bounce"></div>
            <div class="w-1.5 h-1.5 bg-green-400 rounded-full animate-bounce [animation-delay:0.2s]"></div>
            <div class="w-1.5 h-1.5 bg-green-400 rounded-full animate-bounce [animation-delay:0.4s]"></div>
          </div>
          <span>Kizi is searching the cosmos...</span>
        </div>

        <!-- Chat Input Form -->
        <form id="chat-form" class="p-3 bg-black/80 border-t border-green-900/40 flex items-center gap-2">
          <input 
            type="text" 
            id="user-input" 
            placeholder="Ask Kizi for a walkthrough, game tip, or cheat code..." 
            class="flex-grow bg-green-950/20 border border-green-500/20 focus:border-green-400 focus:outline-none rounded-2xl px-4 py-3 text-sm text-green-100 placeholder-green-700/60 transition-all"
            required
            autocomplete="off"
          >
          <button type="submit" class="bg-green-500 hover:bg-green-400 text-black px-5 py-3 rounded-2xl font-bold transition-all flex items-center justify-center gap-2">
            <span class="hidden sm:inline">Send</span>
            <i class="fas fa-paper-plane"></i>
          </button>
        </form>
      </div>

      <!-- Quick Actions Board -->
      <div class="bg-gradient-to-r from-green-950/20 to-black/60 border border-green-900/40 rounded-3xl p-5">
        <h3 class="kizi-font text-lg text-green-400 mb-3"><i class="fas fa-bolt mr-2"></i>Quick Assistant Actions</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <button onclick="quickAction('Give me a fun walkthrough strategy for Fireboy & Watergirl Forest Temple')" class="bg-green-900/20 hover:bg-green-900/40 border border-green-500/20 rounded-xl p-2.5 text-xs text-green-300 transition-all text-left flex flex-col justify-between h-20">
            <i class="fas fa-fire-alt text-orange-400 text-lg mb-1"></i>
            <span>Forest Temple Walkthrough</span>
          </button>
          <button onclick="quickAction('Generate an interactive mini text-adventure game about Snail Bob exploring a cyber castle')" class="bg-green-900/20 hover:bg-green-900/40 border border-green-500/20 rounded-xl p-2.5 text-xs text-green-300 transition-all text-left flex flex-col justify-between h-20">
            <i class="fas fa-brain text-purple-400 text-lg mb-1"></i>
            <span>AI Text Adventure Creator</span>
          </button>
          <button onclick="quickAction('Who is Kizi? Tell me your story!')" class="bg-green-900/20 hover:bg-green-900/40 border border-green-500/20 rounded-xl p-2.5 text-xs text-green-300 transition-all text-left flex flex-col justify-between h-20 col-span-2 sm:col-span-1">
            <i class="fas fa-user-astronaut text-green-400 text-lg mb-1"></i>
            <span>Meet Kizi Mascot</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Right Column: Interactive Gaming Zone (Lg: 5 cols) -->
    <div class="lg:col-span-5 flex flex-col space-y-6">
      
      <!-- Interactive Mini Game Emulator Card -->
      <div class="bg-black/80 border border-green-900/60 rounded-3xl overflow-hidden flex flex-col kizi-glow relative">
        <!-- Tabs for Mini-Games -->
        <div class="flex border-b border-green-900/40 bg-green-950/20">
          <button id="tab-game1" onclick="switchGame('kart')" class="flex-1 py-3 text-center text-xs kizi-font tracking-wider border-b-2 border-green-500 text-green-400 bg-black/40 transition-all flex items-center justify-center gap-2">
            <i class="fas fa-car-side"></i> Kizi Kart Retro
          </button>
          <button id="tab-game2" onclick="switchGame('maze')" class="flex-1 py-3 text-center text-xs kizi-font tracking-wider border-b-2 border-transparent text-green-600 hover:text-green-400 transition-all flex items-center justify-center gap-2">
            <i class="fas fa-bug"></i> Snail Maze Escape
          </button>
        </div>

        <!-- Emulator Display Area -->
        <div class="relative bg-black h-[350px] flex flex-col justify-between items-center overflow-hidden crt">
          
          <!-- Kizi Kart Retro Game Canvas -->
          <div id="kart-game-container" class="absolute inset-0 w-full h-full flex flex-col justify-between">
            <div class="absolute top-2 left-2 z-10 flex space-x-2">
              <span class="bg-black/70 text-green-400 px-2 py-1 rounded text-xs font-mono border border-green-500/30">
                SCORE: <span id="kart-score">0</span>
              </span>
              <span class="bg-black/70 text-green-400 px-2 py-1 rounded text-xs font-mono border border-green-500/30">
                LAPS: <span id="kart-laps">1</span>
              </span>
            </div>
            
            <div id="kart-start-screen" class="absolute inset-0 bg-black/90 backdrop-blur-sm flex flex-col items-center justify-center text-center p-4 z-30">
              <h2 class="kizi-font text-2xl text-green-400 mb-2 animate-pulse"><i class="fas fa-car-side mr-2"></i>KIZI KART RETRO</h2>
              <p class="text-xs text-green-300 max-w-xs mb-4">Drive fast, dodge incoming space meteor obstacles, and collect golden energy rings!</p>
              <button onclick="startKartGame()" class="bg-green-500 hover:bg-green-400 text-black font-bold px-6 py-2.5 rounded-full text-sm kizi-font transition-all transform hover:scale-105">
                START ENGINE
              </button>
              <div class="mt-4 flex items-center justify-center gap-4 text-xs text-green-500">
                <span><kbd class="bg-green-900/60 px-1.5 py-0.5 rounded text-[10px]">A</kbd> / <kbd class="bg-green-900/60 px-1.5 py-0.5 rounded text-[10px]">D</kbd> or <kbd class="bg-green-900/60 px-1.5 py-0.5 rounded text-[10px]">⬅</kbd> <kbd class="bg-green-900/60 px-1.5 py-0.5 rounded text-[10px]">➡</kbd> Steer</span>
              </div>
            </div>

            <!-- Canvas element -->
            <canvas id="kartCanvas" class="w-full h-full block bg-[#102a18]"></canvas>

            <!-- Touch Controllers (Perfect for Mobile users!) -->
            <div class="absolute bottom-4 left-0 right-0 flex justify-between px-6 z-20 pointer-events-none">
              <button id="btn-steer-left" class="pointer-events-auto w-14 h-14 bg-green-500/20 active:bg-green-500/50 border border-green-500/40 rounded-full flex items-center justify-center text-green-400 text-2xl select-none">
                <i class="fas fa-arrow-left"></i>
              </button>
              <button id="btn-steer-right" class="pointer-events-auto w-14 h-14 bg-green-500/20 active:bg-green-500/50 border border-green-500/40 rounded-full flex items-center justify-center text-green-400 text-2xl select-none">
                <i class="fas fa-arrow-right"></i>
              </button>
            </div>
          </div>

          <!-- Snail Maze Escape Game -->
          <div id="maze-game-container" class="absolute inset-0 w-full h-full bg-slate-950 flex flex-col justify-between hidden">
            <div class="absolute top-2 left-2 z-10 flex space-x-2">
              <span class="bg-black/70 text-yellow-400 px-2 py-1 rounded text-xs font-mono border border-yellow-500/30">
                TIME: <span id="maze-timer">45s</span>
              </span>
              <span class="bg-black/70 text-green-400 px-2 py-1 rounded text-xs font-mono border border-green-500/30">
                ITEMS: <span id="maze-items">0/3</span>
              </span>
            </div>

            <div id="maze-start-screen" class="absolute inset-0 bg-black/90 backdrop-blur-sm flex flex-col items-center justify-center text-center p-4 z-30">
              <h2 class="kizi-font text-2xl text-yellow-500 mb-2 animate-pulse"><i class="fas fa-bug mr-2"></i>SNAIL MAZE ESCAPE</h2>
              <p class="text-xs text-gray-300 max-w-xs mb-4">Guide little Snail Bob through the security grid to the green energy portal. Grab all 3 strawberries!</p>
              <button onclick="startMazeGame()" class="bg-yellow-500 hover:bg-yellow-400 text-black font-bold px-6 py-2.5 rounded-full text-sm kizi-font transition-all transform hover:scale-105">
                ENTER LABYRINTH
              </button>
            </div>

            <!-- Canvas element -->
            <canvas id="mazeCanvas" class="w-full h-full block"></canvas>

            <!-- Maze Controls for touch / simple interaction -->
            <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 z-20 pointer-events-none">
              <button id="maze-up" class="pointer-events-auto w-10 h-10 bg-yellow-500/20 active:bg-yellow-500/50 border border-yellow-500/40 rounded-lg flex items-center justify-center text-yellow-400"><i class="fas fa-arrow-up"></i></button>
              <div class="flex gap-4">
                <button id="maze-left" class="pointer-events-auto w-10 h-10 bg-yellow-500/20 active:bg-yellow-500/50 border border-yellow-500/40 rounded-lg flex items-center justify-center text-yellow-400"><i class="fas fa-arrow-left"></i></button>
                <button id="maze-down" class="pointer-events-auto w-10 h-10 bg-yellow-500/20 active:bg-yellow-500/50 border border-yellow-500/40 rounded-lg flex items-center justify-center text-yellow-400"><i class="fas fa-arrow-down"></i></button>
                <button id="maze-right" class="pointer-events-auto w-10 h-10 bg-yellow-500/20 active:bg-yellow-500/50 border border-yellow-500/40 rounded-lg flex items-center justify-center text-yellow-400"><i class="fas fa-arrow-right"></i></button>
              </div>
            </div>
          </div>

        </div>
        
        <!-- Game Stats & Achievements footer -->
        <div class="bg-green-950/30 p-4 border-t border-green-900/40 flex justify-between items-center text-xs">
          <div class="flex items-center space-x-2">
            <span class="inline-block w-2.5 h-2.5 bg-yellow-500 rounded-full animate-pulse"></span>
            <span class="text-green-300">Emulator Mode: Active</span>
          </div>
          <span class="text-green-500 font-mono">Hi-Score: <span id="saved-hiscore">1250</span> pts</span>
        </div>
      </div>

      <!-- Kizi Nostalgia Retro Games Library -->
      <div class="bg-black/40 border border-green-900/40 rounded-3xl p-5 space-y-4">
        <h3 class="kizi-font text-lg text-green-400 flex items-center justify-between">
          <span><i class="fas fa-gamepad mr-2"></i>Kizi Classics Catalog</span>
          <span class="text-xs text-green-500">Tips Available</span>
        </h3>
        
        <div class="space-y-3">
          <!-- Game Row 1 -->
          <div class="flex items-center justify-between bg-green-950/10 border border-green-500/10 rounded-2xl p-3 hover:bg-green-900/20 transition-all cursor-pointer" onclick="quickAction('Give me tips for Bob the Robber 4')">
            <div class="flex items-center space-x-3">
              <span class="w-10 h-10 bg-yellow-500/10 border border-yellow-500/30 rounded-xl flex items-center justify-center text-yellow-400">
                <i class="fas fa-user-secret"></i>
              </span>
              <div>
                <h4 class="font-bold text-sm text-green-200">Bob the Robber 4</h4>
                <p class="text-[10px] text-green-500">Sneaking & Stealth Puzzle</p>
              </div>
            </div>
            <span class="text-xs text-green-400 bg-green-900/40 px-2 py-1 rounded-md border border-green-500/20">Ask Guide</span>
          </div>

          <!-- Game Row 2 -->
          <div class="flex items-center justify-between bg-green-950/10 border border-green-500/10 rounded-2xl p-3 hover:bg-green-900/20 transition-all cursor-pointer" onclick="quickAction('Explain the mechanics of Fireboy and Watergirl')">
            <div class="flex items-center space-x-3">
              <span class="w-10 h-10 bg-red-500/10 border border-red-500/30 rounded-xl flex items-center justify-center text-red-400">
                <i class="fas fa-tint"></i>
              </span>
              <div>
                <h4 class="font-bold text-sm text-green-200">Fireboy & Watergirl</h4>
                <p class="text-[10px] text-green-500">Cooperative Platforming</p>
              </div>
            </div>
            <span class="text-xs text-green-400 bg-green-900/40 px-2 py-1 rounded-md border border-green-500/20">Ask Guide</span>
          </div>

          <!-- Game Row 3 -->
          <div class="flex items-center justify-between bg-green-950/10 border border-green-500/10 rounded-2xl p-3 hover:bg-green-900/20 transition-all cursor-pointer" onclick="quickAction('What are Snail Bob puzzle mechanics?')">
            <div class="flex items-center space-x-3">
              <span class="w-10 h-10 bg-blue-500/10 border border-blue-500/30 rounded-xl flex items-center justify-center text-blue-400">
                <i class="fas fa-hourglass-half"></i>
              </span>
              <div>
                <h4 class="font-bold text-sm text-green-200">Snail Bob 2</h4>
                <p class="text-[10p]
